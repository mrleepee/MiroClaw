# LLM API Configuration (any OpenAI SDK-compatible LLM API)
# Minimax 2.7: https://platform.minimax.io/docs/api-reference/api-overview
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api.minimax.chat/v1
LLM_MODEL_NAME=MiniMax-M1

# ===== Neo4j Graph Database =====
# Local Neo4j instance (started via docker compose)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=miroclaw_password

# ===== Embedding Model (Optional) =====
# Default: Qwen/Qwen3-Embedding-4B
# Set to a smaller model if GPU/memory is limited
# EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# ===== Boost LLM Configuration (Optional) =====
# Use a second LLM for parallel simulations to avoid rate limits
# Only add these if you want to use a separate LLM for the boost
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here
